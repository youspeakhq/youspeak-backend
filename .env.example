# Application
APP_NAME=YouSpeak Backend
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=True
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql://youspeak_user:your_secure_password@localhost:5432/youspeak_db

# Security & Authentication
SECRET_KEY=your-secret-key-here-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
# ALLOWED_ORIGINS: Comma-separated list of specific allowed origins
# ALLOWED_ORIGINS_REGEX: Regex pattern for dynamic origin matching (e.g., all subdomains)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173
ALLOWED_ORIGINS_REGEX=https://.*\.youspeakhq\.com
ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
ALLOWED_HEADERS=*

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# Email (Resend) - https://resend.com
# Default onboarding@resend.dev sends to your Resend account email only (no domain setup).
RESEND_API_KEY=
EMAIL_FROM=YouSpeak <onboarding@resend.dev>
FRONTEND_SIGNUP_URL=https://app.youspeak.com/signup
FRONTEND_RESET_PASSWORD_URL=https://app.youspeak.com/reset-password

# Storage (Cloudflare R2) - https://developers.cloudflare.com/r2/
# Create API token: Cloudflare Dashboard → R2 → Manage R2 API Tokens → Create API token (Object Read & Write).
STORAGE_PUBLIC_BASE_URL=https://pub-2dc65d0e715b43b5ab0985e9c0eb514c.r2.dev
R2_ACCOUNT_ID=a9edc14299c7518ddfbdd714348ceb61
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=youspeakweb

# Azure Speech (Pronunciation Assessment) - https://portal.azure.com
# Create Speech resource: Azure Portal → AI + Machine Learning → Speech
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=60

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Database Connection Pool
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# Curriculum service (core API proxy target; optional)
CURRICULUM_SERVICE_URL=http://localhost:8001
CURRICULUM_INTERNAL_SECRET=

# Curriculum service – AI generation (Bedrock). Required for /curriculums/generate, extract, merge.
# On ECS the task role must have bedrock:InvokeModel. Locally, set AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY (or use a profile).
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0

# Cloudflare RealtimeKit (Audio Conferencing) - https://developers.cloudflare.com/realtime/realtimekit/
# 1. Get Account ID from Cloudflare dashboard → right sidebar (or reuse R2_ACCOUNT_ID)
# 2. Create a RealtimeKit App: Dashboard → Realtime → RealtimeKit → Create App
# 3. Create presets in the App:
#    - "teacher-host": Host role with publish audio/video + moderator controls
#    - "student-audience": Participant role with publish audio only
# 4. Create API token: Dashboard → API Tokens → Create Token → "Realtime Admin" permissions
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_REALTIMEKIT_APP_ID=
CLOUDFLARE_API_TOKEN=
