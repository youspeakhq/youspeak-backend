{
  "family": "youspeak-arena-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "ephemeralStorage": { "sizeInGiB": 50 },
  "executionRoleArn": "arn:aws:iam::497068062563:role/youspeak-ecs-execution-role-staging",
  "taskRoleArn": "arn:aws:iam::497068062563:role/youspeak-ecs-task-role-staging",
  "containerDefinitions": [
    {
      "name": "youspeak-arena",
      "image": "497068062563.dkr.ecr.us-east-1.amazonaws.com/youspeak-arena-backend:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8002,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "ENVIRONMENT",
          "value": "production"
        },
        {
          "name": "API_V1_PREFIX",
          "value": "/api/v1/arenas/live"
        },
        {
          "name": "LOG_LEVEL",
          "value": "INFO"
        },
        {
          "name": "LOG_FORMAT",
          "value": "json"
        },
        { "name": "SERVICE_ROLE", "value": "api" },
        { "name": "CORE_SERVICE_URL", "value": "https://api.youspeakhq.com" }
      ],
      "secrets": [
        {
          "name": "INTERNAL_API_SECRET",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:497068062563:secret:youspeak/internal-api-secret-staging-X8j2Lp"
        },
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:497068062563:secret:youspeak/database-url-staging-ALTD0S"
        },
        {
          "name": "REDIS_URL",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:497068062563:secret:youspeak/redis-url-staging-zWqRpX"
        },
        {
          "name": "SECRET_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:497068062563:secret:youspeak/secret-key-staging-tmNJnc"
        },
        { "name": "CLOUDFLARE_ACCOUNT_ID", "valueFrom": "arn:aws:secretsmanager:us-east-1:497068062563:secret:youspeak/cloudflare-account-id-staging-gsmmGU" },
        { "name": "CLOUDFLARE_API_TOKEN", "valueFrom": "arn:aws:secretsmanager:us-east-1:497068062563:secret:youspeak/cloudflare-api-token-staging-xOjwx3" },
        { "name": "CLOUDFLARE_REALTIMEKIT_APP_ID", "valueFrom": "arn:aws:secretsmanager:us-east-1:497068062563:secret:youspeak/cloudflare-realtimekit-app-id-staging-JOgL44" },
        { "name": "AZURE_SPEECH_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-1:497068062563:secret:youspeak/azure-speech-key-staging-T7AGIg" },
        { "name": "AZURE_SPEECH_REGION", "valueFrom": "arn:aws:secretsmanager:us-east-1:497068062563:secret:youspeak/azure-speech-region-staging-2XtOsh" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/youspeak-arena",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "python -c 'import urllib.request; urllib.request.urlopen(\"http://localhost:8002/health\")' || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ]
}
