{
  "family": "youspeak-migration-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "ephemeralStorage": { "sizeInGiB": 21 },
  "executionRoleArn": "arn:aws:iam::497068062563:role/youspeak-ecs-execution-role-staging",
  "taskRoleArn": "arn:aws:iam::497068062563:role/youspeak-ecs-task-role-staging",
  "containerDefinitions": [
    {
      "name": "youspeak-migration",
      "image": "497068062563.dkr.ecr.us-east-1.amazonaws.com/youspeak-backend:migration",
      "essential": true,
      "secrets": [
        { "name": "DATABASE_URL", "valueFrom": "arn:aws:secretsmanager:us-east-1:497068062563:secret:youspeak/database-url-staging-ALTD0S" },
        { "name": "SECRET_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-1:497068062563:secret:youspeak/secret-key-staging-tmNJnc" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/youspeak-api",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}
