{
  "family": "youspeak-api-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "ephemeralStorage": { "sizeInGiB": 50 },
  "executionRoleArn": "arn:aws:iam::497068062563:role/youspeak-ecs-execution-role-staging",
  "taskRoleArn": "arn:aws:iam::497068062563:role/youspeak-ecs-task-role-staging",
  "containerDefinitions": [
    {
      "name": "youspeak-api",
      "image": "497068062563.dkr.ecr.us-east-1.amazonaws.com/youspeak-backend:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "ENVIRONMENT",
          "value": "production"
        },
        {
          "name": "API_V1_PREFIX",
          "value": "/api/v1"
        },
        {
          "name": "LOG_LEVEL",
          "value": "INFO"
        },
        {
          "name": "LOG_FORMAT",
          "value": "json"
        },
        { "name": "STORAGE_PUBLIC_BASE_URL", "value": "https://pub-e5cc183f0ebf487c89df255c34fc385d.r2.dev" },
        { "name": "CURRICULUM_SERVICE_URL", "value": "http://internal-youspeak-curric-int-prod-1443419019.us-east-1.elb.amazonaws.com" },
        { "name": "EMAIL_FROM", "value": "YouSpeak <noreply@youspeakhq.com>" }
      ],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:497068062563:secret:youspeak/database-url-staging-ALTD0S"
        },
        {
          "name": "REDIS_URL",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:497068062563:secret:youspeak/redis-url-staging-zWqRpX"
        },
        {
          "name": "SECRET_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:497068062563:secret:youspeak/secret-key-staging-tmNJnc"
        },
        {
          "name": "RESEND_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:497068062563:secret:youspeak/resend-api-key-staging-0Cw2d0"
        },
        { "name": "R2_ACCOUNT_ID", "valueFrom": "arn:aws:secretsmanager:us-east-1:497068062563:secret:youspeak/r2-account-id-staging-VRAAN4" },
        { "name": "R2_ACCESS_KEY_ID", "valueFrom": "arn:aws:secretsmanager:us-east-1:497068062563:secret:youspeak/r2-access-key-id-staging-6RxNk5" },
        { "name": "R2_SECRET_ACCESS_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-1:497068062563:secret:youspeak/r2-secret-access-key-staging-BN4EJ2" },
        { "name": "R2_BUCKET_NAME", "valueFrom": "arn:aws:secretsmanager:us-east-1:497068062563:secret:youspeak/r2-bucket-name-staging-IJH101" },
        { "name": "CLOUDFLARE_ACCOUNT_ID", "valueFrom": "arn:aws:secretsmanager:us-east-1:497068062563:secret:youspeak/cloudflare-account-id-staging-gsmmGU" },
        { "name": "CLOUDFLARE_API_TOKEN", "valueFrom": "arn:aws:secretsmanager:us-east-1:497068062563:secret:youspeak/cloudflare-api-token-staging-xOjwx3" },
        { "name": "CLOUDFLARE_REALTIMEKIT_APP_ID", "valueFrom": "arn:aws:secretsmanager:us-east-1:497068062563:secret:youspeak/cloudflare-realtimekit-app-id-staging-JOgL44" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/youspeak-api",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "python -c 'import urllib.request; urllib.request.urlopen(\"http://localhost:8000/health\")' || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ]
}
