{
  "family": "youspeak-curriculum-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "ephemeralStorage": { "sizeInGiB": 50 },
  "executionRoleArn": "arn:aws:iam::497068062563:role/youspeak-ecs-execution-role-production",
  "taskRoleArn": "arn:aws:iam::497068062563:role/youspeak-ecs-task-role-production",
  "containerDefinitions": [
    {
      "name": "youspeak-curriculum",
      "image": "497068062563.dkr.ecr.us-east-1.amazonaws.com/youspeak-curriculum-backend:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8001,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "ENVIRONMENT", "value": "production" },
        { "name": "AWS_REGION", "value": "us-east-1" },
        { "name": "BEDROCK_MODEL_ID", "value": "amazon.nova-lite-v1:0" }
      ],
      "secrets": [
        { "name": "DATABASE_URL", "valueFrom": "arn:aws:secretsmanager:us-east-1:497068062563:secret:youspeak/database-url-production-npnxkc" },
        { "name": "R2_ACCOUNT_ID", "valueFrom": "arn:aws:secretsmanager:us-east-1:497068062563:secret:youspeak/r2-account-id-production-3kogBa" },
        { "name": "R2_ACCESS_KEY_ID", "valueFrom": "arn:aws:secretsmanager:us-east-1:497068062563:secret:youspeak/r2-access-key-id-production-CidXfa" },
        { "name": "R2_SECRET_ACCESS_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-1:497068062563:secret:youspeak/r2-secret-access-key-production-OgabM9" },
        { "name": "R2_BUCKET_NAME", "valueFrom": "arn:aws:secretsmanager:us-east-1:497068062563:secret:youspeak/r2-bucket-name-production-jnDkpc" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/youspeak-curriculum-api",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "python3 -c \"import urllib.request; urllib.request.urlopen('http://localhost:8001/health')\" || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ]
}
