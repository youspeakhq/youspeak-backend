# Minimal stub for CI Docker Compose: only /health returns 200 so API can become healthy.
# Avoids building the full curriculum image (torch/docling) on the runner and prevents "No space left on device".
FROM python:3.9-slim
WORKDIR /app
COPY services/curriculum/ci_stub_server.py .
EXPOSE 8001
CMD ["python3", "-u", "ci_stub_server.py"]
